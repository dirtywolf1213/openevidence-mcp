OE_MCP_BASE_URL=https://www.openevidence.com
# OE_MCP_ROOT_DIR=/absolute/path/.openevidence-mcp
# OE_MCP_COOKIES_PATH=/absolute/path/openevidence-mcp/cookies.json
# OE_MCP_AUTH_STATE_PATH is still accepted as a legacy alias for OE_MCP_COOKIES_PATH.
# OE_MCP_ARTIFACT_DIR=/tmp/openevidence-mcp
# OE_MCP_CROSSREF_MAILTO=you@example.com
# OE_MCP_CROSSREF_VALIDATE=1

# Browser-extension relay (localhost). The MCP server routes ALL requests through
# the extension's logged-in tab by default; cookies.json is used only by the Python
# collections tooling and `npm run doctor` / `login`.
#   all (default): oe_ask + all reads go through the extension; no cookie fallback.
#   off:           reads use cookies.json; only the ask still needs the extension.
# The relay runs as a standalone daemon (auto-spawned, shared by every session, so
# many MCP servers funnel through the one tab). It survives session restarts and is
# respawned on demand. Run/inspect manually with `npm run relay`.
# OE_MCP_RELAY_TRANSPORT=all
# OE_MCP_RELAY=1            # set 0 to disable the relay entirely
# OE_MCP_RELAY_PORT=8787    # must match the extension
# OE_MCP_RELAY_PID_PATH=~/.openevidence-mcp/relay.pid
# OE_MCP_RELAY_LOG_PATH=~/.openevidence-mcp/relay.log

# Polling controls for oe_ask when wait_for_completion=true
OE_MCP_POLL_INTERVAL_MS=1200
OE_MCP_POLL_TIMEOUT_MS=180000

{
	"name": "openevidence-mcp",
	"version": "0.3.1",
	"description": "Unofficial MCP server for OpenEvidence — authenticated through your own logged-in browser tab via a Chromium relay extension (no API key, no Playwright). Fire-and-forget asks, a shared relay daemon for concurrent sessions, BibTeX + Crossref citations.",
	"main": "dist/server.js",
	"bin": {
		"openevidence-mcp": "./dist/server.js"
	},
	"directories": {
		"example": "examples"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx src/server.ts",
		"start": "node dist/server.js",
		"relay": "node dist/relay-daemon.js",
		"login": "tsx src/login.ts",
		"import-cookies": "tsx src/login.ts",
		"fingerprint": "tsx src/fingerprint.ts",
		"doctor": "tsx src/doctor.ts",
		"cookies:safari": "python3 scripts/safari_cookies.py --out cookies.json",
		"check": "tsc -p tsconfig.json --noEmit",
		"test": "tsx --test test/*.test.ts",
		"smoke": "tsx src/smoke.ts"
	},
	"files": [
		"dist/",
		"scripts/*.py",
		"scripts/*.sh",
		"scripts/*.ps1",
		"examples/",
		".env.example",
		"LICENSE",
		"NOTICE",
		"README.md",
		"README.AI.md",
		"CHANGELOG.md",
		"CITATION.cff"
	],
	"engines": {
		"node": ">=20"
	},
	"keywords": [
		"mcp",
		"mcp-server",
		"openevidence",
		"medical-ai",
		"clinical-decision-support",
		"evidence-based-medicine",
		"healthcare",
		"cookies",
		"codex",
		"claude",
		"browser-extension",
		"datadome",
		"relay"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/htlin222/openevidence-mcp.git"
	},
	"homepage": "https://github.com/htlin222/openevidence-mcp",
	"bugs": {
		"url": "https://github.com/htlin222/openevidence-mcp/issues"
	},
	"author": "Hsiehting Lin",
	"license": "Apache-2.0",
	"type": "module",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.26.0",
		"dotenv": "^17.3.1",
		"node-html-parser": "^9.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.3.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
